<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard Disparo Pro</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
  :root {
    --bg: #0e0f11;
    --card: #17181b;
    --border: #26272b;
    --text: #f3f3f2;
    --text-secondary: #9a9a97;
    --text-muted: #6b6b68;
    --accent: #378ADD;
    --success: #1D9E75;
    --danger: #E24B4A;
    --warning: #EF9F27;
    --radius: 10px;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    padding: 2rem;
  }
  .wrap { max-width: 1100px; margin: 0 auto; }
  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }
  h1 { font-size: 20px; font-weight: 500; margin: 0; }
  .status {
    font-size: 13px;
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--text-muted);
  }
  .dot.live { background: var(--success); }
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 12px;
    margin-bottom: 1.5rem;
  }
  .card {
    background: var(--card);
    border: 0.5px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
  }
  .card .label {
    font-size: 13px;
    color: var(--text-secondary);
    margin-bottom: 6px;
  }
  .card .value {
    font-size: 26px;
    font-weight: 500;
  }
  .card .value.success { color: var(--success); }
  .card .value.danger { color: var(--danger); }
  .section {
    background: var(--card);
    border: 0.5px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    margin-bottom: 1.5rem;
  }
  .section h2 {
    font-size: 16px;
    font-weight: 500;
    margin: 0 0 1rem;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }
  th, td {
    text-align: left;
    padding: 8px 10px;
    border-bottom: 0.5px solid var(--border);
  }
  th {
    color: var(--text-secondary);
    font-weight: 500;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  td.num, th.num { text-align: right; }
  .rank-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px; height: 22px;
    border-radius: 50%;
    background: #1D2F26;
    color: #5DCAA5;
    font-size: 12px;
    font-weight: 500;
    margin-right: 8px;
  }
  .user-name-wrap {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .edit-name-btn {
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    font-size: 12px;
    padding: 2px 6px;
    border-radius: 4px;
  }
  .edit-name-btn:hover {
    color: var(--accent);
    background: rgba(55,138,221,0.1);
  }
  .name-input {
    background: var(--bg);
    border: 0.5px solid var(--accent);
    border-radius: 4px;
    color: var(--text);
    font-size: 14px;
    padding: 2px 6px;
    width: 140px;
  }
  .empty {
    color: var(--text-muted);
    font-size: 14px;
    padding: 1rem 0;
    text-align: center;
  }
  .config-banner {
    background: #2A2311;
    border: 0.5px solid #63481a;
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    margin-bottom: 1.5rem;
    font-size: 13px;
    color: #EF9F27;
    display: none;
  }
  .config-banner.show { display: block; }
  #chart-wrap { position: relative; height: 260px; }

  .filter-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: flex-end;
    margin-bottom: 1rem;
  }
  .filter-field {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .filter-field label {
    font-size: 12px;
    color: var(--text-secondary);
  }
  .filter-field select,
  .filter-field input {
    background: var(--bg);
    border: 0.5px solid var(--border);
    border-radius: 6px;
    color: var(--text);
    font-size: 14px;
    padding: 8px 10px;
    min-width: 180px;
  }
  .filter-field input[type="date"] { min-width: 150px; }
  .btn-primary {
    background: var(--accent);
    border: none;
    border-radius: 6px;
    color: #fff;
    font-size: 14px;
    font-weight: 500;
    padding: 9px 18px;
    cursor: pointer;
  }
  .btn-primary:hover { opacity: 0.9; }
  .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }

  .search-summary {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 12px;
    margin-bottom: 1rem;
  }
  .search-summary .mini-card {
    background: var(--bg);
    border: 0.5px solid var(--border);
    border-radius: 8px;
    padding: 0.75rem 1rem;
  }
  .search-summary .mini-card .label { font-size: 12px; color: var(--text-secondary); margin-bottom: 4px; }
  .search-summary .mini-card .value { font-size: 20px; font-weight: 500; }

  .status-pill {
    display: inline-block;
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 999px;
    font-weight: 500;
  }
  .status-pill.ok { background: #1D2F26; color: #5DCAA5; }
  .status-pill.pending { background: #2A2311; color: #EF9F27; }
  .status-pill.fail { background: #2E1717; color: #E5807F; }
</style>
</head>
<body>
<div class="wrap">
  <header>
    <h1>Dashboard Disparo Pro</h1>
    <div class="status">
      <span class="dot" id="status-dot"></span>
      <span id="status-text">Conectando...</span>
    </div>
  </header>

  <div class="config-banner" id="config-banner">
    Nenhum dado recebido ainda. Configure o webhook DLR/MO no painel da Disparo Pro apontando para o endpoint
    <code id="webhook-url-hint"></code> e rode o poll-balance para começar a ver dados aqui.
  </div>

  <div class="cards">
    <div class="card">
      <div class="label">Saldo da plataforma</div>
      <div class="value" id="card-saldo">--</div>
    </div>
    <div class="card">
      <div class="label">SMS entregues (24h)</div>
      <div class="value success" id="card-entregues">--</div>
    </div>
    <div class="card">
      <div class="label">SMS com falha (24h)</div>
      <div class="value danger" id="card-falhas">--</div>
    </div>
    <div class="card">
      <div class="label">Total de eventos (24h)</div>
      <div class="value" id="card-total">--</div>
    </div>
  </div>

  <div class="section">
    <h2>Envios ao longo do tempo (últimas 24h)</h2>
    <div id="chart-wrap">
      <canvas id="chart" role="img" aria-label="Gráfico de linha mostrando SMS entregues por hora nas últimas 24 horas"></canvas>
    </div>
  </div>

  <div class="section">
    <h2>Buscar por usuário e período</h2>
    <div class="filter-row">
      <div class="filter-field">
        <label for="filter-user">Usuário</label>
        <select id="filter-user">
          <option value="">Carregando usuários...</option>
        </select>
      </div>
      <div class="filter-field">
        <label for="filter-start">Data inicial</label>
        <input type="date" id="filter-start" />
      </div>
      <div class="filter-field">
        <label for="filter-end">Data final</label>
        <input type="date" id="filter-end" />
      </div>
      <button class="btn-primary" id="btn-search">Buscar</button>
    </div>

    <div id="search-results" style="display:none;">
      <div class="search-summary">
        <div class="mini-card">
          <div class="label">Total de SMS disparados</div>
          <div class="value" id="search-total">--</div>
        </div>
        <div class="mini-card">
          <div class="label">Dias distintos com envio</div>
          <div class="value" id="search-dias">--</div>
        </div>
        <div class="mini-card">
          <div class="label">Primeiro envio no período</div>
          <div class="value" id="search-primeiro" style="font-size:14px;">--</div>
        </div>
        <div class="mini-card">
          <div class="label">Último envio no período</div>
          <div class="value" id="search-ultimo" style="font-size:14px;">--</div>
        </div>
      </div>
      <table>
        <thead>
          <tr>
            <th>Data</th>
            <th>Horário</th>
            <th>Destino</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody id="search-body">
        </tbody>
      </table>
    </div>
    <div id="search-empty" class="empty" style="display:none;">Nenhum envio encontrado para esse usuário no período selecionado.</div>
  </div>

  <div class="section">
    <h2>Ranking de envios por usuário/subconta</h2>
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Usuário</th>
          <th class="num">Entregues</th>
          <th class="num">Aguardando</th>
          <th class="num">Falhas</th>
          <th class="num">Total</th>
          <th>Último envio</th>
        </tr>
      </thead>
      <tbody id="ranking-body">
        <tr><td colspan="7" class="empty">Aguardando dados...</td></tr>
      </tbody>
    </table>
  </div>
</div>

<script>
// ---- CONFIGURAÇÃO ----
const SUPABASE_URL = "https://nbkhnzecsezxkhrevyqj.supabase.co";
const SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5ia2huemVjc2V6eGtocmV2eXFqIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODQwMDE0MTgsImV4cCI6MjA5OTU3NzQxOH0.ZkHb0c21H97XM55V5dYSOefVZNeVoMdnIWEcag2PTZQ";
// -----------------------

const { createClient } = supabase;
const db = createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

document.getElementById("webhook-url-hint").textContent =
  SUPABASE_URL + "/functions/v1/receive-webhook?secret=SEU_SEGREDO";

function setStatus(live) {
  document.getElementById("status-dot").classList.toggle("live", live);
  document.getElementById("status-text").textContent = live ? "Ao vivo" : "Conectando...";
}

function fmtMoney(v) {
  return new Intl.NumberFormat("pt-BR", { style: "currency", currency: "BRL" }).format(v);
}

function fmtDate(d) {
  if (!d) return "--";
  return new Date(d).toLocaleString("pt-BR", { day: "2-digit", month: "2-digit", hour: "2-digit", minute: "2-digit" });
}

let chart;
function renderChart(buckets) {
  const ctx = document.getElementById("chart");
  const labels = buckets.map(b => b.label);
  const data = buckets.map(b => b.count);
  if (chart) {
    chart.data.labels = labels;
    chart.data.datasets[0].data = data;
    chart.update();
    return;
  }
  chart = new Chart(ctx, {
    type: "line",
    data: {
      labels,
      datasets: [{
        label: "SMS entregues",
        data,
        borderColor: "#378ADD",
        backgroundColor: "rgba(55,138,221,0.1)",
        fill: true,
        tension: 0.3,
        pointRadius: 0,
        borderWidth: 2,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: { grid: { display: false }, ticks: { color: "#6b6b68", maxRotation: 0, autoSkip: true } },
        y: { beginAtZero: true, grid: { color: "#26272b" }, ticks: { color: "#6b6b68" } }
      }
    }
  });
}

async function loadSaldo() {
  const { data, error } = await db
    .from("saldo_history")
    .select("saldo, captured_at")
    .order("captured_at", { ascending: false })
    .limit(1);
  if (!error && data && data.length > 0) {
    document.getElementById("card-saldo").textContent = fmtMoney(data[0].saldo);
  }
}

async function loadRanking() {
  const { data, error } = await db
    .from("ranking_envios")
    .select("*")
    .order("total_eventos", { ascending: false })
    .limit(20);

  const tbody = document.getElementById("ranking-body");
  if (error || !data || data.length === 0) {
    tbody.innerHTML = '<tr><td colspan="7" class="empty">Nenhum dado ainda. Aguardando webhooks da Disparo Pro.</td></tr>';
    document.getElementById("config-banner").classList.add("show");
    return;
  }
  document.getElementById("config-banner").classList.remove("show");
  tbody.innerHTML = data.map((row, i) => `
    <tr>
      <td><span class="rank-badge">${i + 1}</span></td>
      <td>
        <span class="user-name-wrap" data-use-id="${row.sms_use_id}">
          <span class="name-label">${row.nome_usuario}</span>
          <button class="edit-name-btn" onclick="editUserName(${row.sms_use_id}, this)" aria-label="Editar nome">editar</button>
        </span>
      </td>
      <td class="num">${row.entregues}</td>
      <td class="num">${row.enviados_aguardando}</td>
      <td class="num">${row.falhas}</td>
      <td class="num">${row.total_eventos}</td>
      <td>${fmtDate(row.ultimo_envio)}</td>
    </tr>
  `).join("");
}

window.editUserName = function(useId, btn) {
  const wrap = btn.closest(".user-name-wrap");
  const label = wrap.querySelector(".name-label");
  const current = label.textContent;
  wrap.innerHTML = `
    <input class="name-input" type="text" value="${current.startsWith('Usuário ') ? '' : current}" placeholder="Nome da subconta" />
    <button class="edit-name-btn" aria-label="Salvar">salvar</button>
  `;
  const input = wrap.querySelector("input");
  input.focus();
  const save = async () => {
    const nome = input.value.trim();
    if (!nome) return;
    await db.from("subcontas").upsert({ sms_use_id: useId, nome });
    loadRanking();
  };
  wrap.querySelector("button").onclick = save;
  input.addEventListener("keydown", (e) => { if (e.key === "Enter") save(); });
};

async function loadSummaryAndChart() {
  const since = new Date(Date.now() - 24 * 60 * 60 * 1000).toISOString();
  const { data, error } = await db
    .from("sms_events")
    .select("status, created_at")
    .eq("event_type", "dlr")
    .gte("created_at", since);

  if (error || !data) return;

  const entregues = data.filter(d => d.status === "DELIVERED").length;
  const falhas = data.filter(d => ["UNKNOWN","EXPIRED","UNDELIVERABLE","REJECTED","BLACKLIST"].includes(d.status)).length;

  document.getElementById("card-entregues").textContent = entregues;
  document.getElementById("card-falhas").textContent = falhas;
  document.getElementById("card-total").textContent = data.length;

  // Agrupa por hora para o gráfico
  const buckets = {};
  for (let i = 23; i >= 0; i--) {
    const d = new Date(Date.now() - i * 60 * 60 * 1000);
    const key = d.toISOString().slice(0, 13);
    buckets[key] = { label: d.getHours() + "h", count: 0 };
  }
  data.filter(d => d.status === "DELIVERED").forEach(d => {
    const key = d.created_at.slice(0, 13);
    if (buckets[key]) buckets[key].count++;
  });
  renderChart(Object.values(buckets));
}

async function loadAll() {
  await Promise.all([loadSaldo(), loadRanking(), loadSummaryAndChart(), loadUserOptions()]);
}

// ---- Busca por usuário e período ----

async function loadUserOptions() {
  const sel = document.getElementById("filter-user");
  const previousValue = sel.value;
  const { data, error } = await db
    .from("ranking_envios")
    .select("sms_use_id, nome_usuario")
    .order("nome_usuario", { ascending: true });

  if (error || !data) return;

  sel.innerHTML = '<option value="">Selecione um usuário</option>' +
    data.map(u => `<option value="${u.sms_use_id}">${u.nome_usuario}</option>`).join("");

  if (previousValue) sel.value = previousValue;
}

function fmtDateOnly(d) {
  return new Date(d).toLocaleDateString("pt-BR");
}
function fmtTimeOnly(d) {
  return new Date(d).toLocaleTimeString("pt-BR", { hour: "2-digit", minute: "2-digit", second: "2-digit" });
}

function statusPillClass(status) {
  if (status === "DELIVERED") return "ok";
  if (["SENT", "ACCEPTED"].includes(status)) return "pending";
  return "fail";
}

async function runSearch() {
  const useId = document.getElementById("filter-user").value;
  const start = document.getElementById("filter-start").value;
  const end = document.getElementById("filter-end").value;
  const btn = document.getElementById("btn-search");

  if (!useId) {
    alert("Selecione um usuário para buscar.");
    return;
  }

  btn.disabled = true;
  btn.textContent = "Buscando...";

  let query = db
    .from("sms_events")
    .select("destino, status, data_insercao, created_at")
    .eq("event_type", "dlr")
    .eq("sms_use_id", useId)
    .order("data_insercao", { ascending: false });

  if (start) query = query.gte("data_insercao", `${start}T00:00:00`);
  if (end) query = query.lte("data_insercao", `${end}T23:59:59`);

  const { data, error } = await query.limit(500);

  btn.disabled = false;
  btn.textContent = "Buscar";

  const resultsEl = document.getElementById("search-results");
  const emptyEl = document.getElementById("search-empty");

  if (error || !data || data.length === 0) {
    resultsEl.style.display = "none";
    emptyEl.style.display = "block";
    return;
  }

  emptyEl.style.display = "none";
  resultsEl.style.display = "block";

  const timestamps = data.map(d => d.data_insercao || d.created_at).filter(Boolean);
  const diasDistintos = new Set(timestamps.map(t => t.slice(0, 10))).size;
  const primeiro = timestamps.length ? timestamps.reduce((a, b) => a < b ? a : b) : null;
  const ultimo = timestamps.length ? timestamps.reduce((a, b) => a > b ? a : b) : null;

  document.getElementById("search-total").textContent = data.length;
  document.getElementById("search-dias").textContent = diasDistintos;
  document.getElementById("search-primeiro").textContent = primeiro ? `${fmtDateOnly(primeiro)} às ${fmtTimeOnly(primeiro)}` : "--";
  document.getElementById("search-ultimo").textContent = ultimo ? `${fmtDateOnly(ultimo)} às ${fmtTimeOnly(ultimo)}` : "--";

  document.getElementById("search-body").innerHTML = data.map(row => {
    const ts = row.data_insercao || row.created_at;
    return `
      <tr>
        <td>${fmtDateOnly(ts)}</td>
        <td>${fmtTimeOnly(ts)}</td>
        <td>${row.destino || "--"}</td>
        <td><span class="status-pill ${statusPillClass(row.status)}">${row.status || "--"}</span></td>
      </tr>
    `;
  }).join("");
}

document.getElementById("btn-search").addEventListener("click", runSearch);

// Carga inicial
loadAll().then(() => setStatus(true));

// Tempo real: qualquer INSERT em sms_events ou saldo_history dispara atualização
db.channel("dashboard-updates")
  .on("postgres_changes", { event: "INSERT", schema: "public", table: "sms_events" }, () => loadAll())
  .on("postgres_changes", { event: "INSERT", schema: "public", table: "saldo_history" }, () => loadAll())
  .subscribe((status) => {
    if (status === "SUBSCRIBED") setStatus(true);
  });

// Atualização de segurança a cada 30s, caso o realtime perca conexão
setInterval(loadAll, 30000);
</script>
</body>
</html>
